# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Editor / OS cruft
.DS_Store
.vscode/
.idea/
.claude/

# Generator outputs — keep only the synthetic dataset, ignore the rest.
generator/output/*
!generator/output/
!generator/output/synthetic_dataset.csv

# Reporting outputs — keep only the final report and figures, ignore the rest.
reporting/output/*
!reporting/output/
!reporting/output/report.md
!reporting/output/weber_boxplot_by_condition.png
!reporting/output/weber_interaction_by_site.png
!reporting/output/cv_by_condition.png

# Analysis outputs — keep only the final analysis results, ignore the rest.
analysis/output/*
!analysis/output/
!analysis/output/analysis_report.md

# Notes and materials from the plan phase, which are not intended to be shared.
plan-materials/
